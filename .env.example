# Supabase — get from: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase service role — SERVER ONLY, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Anthropic — get from: console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key

# OpenAI (if using OpenAI model anywhere)
OPENAI_API_KEY=sk-xxx-openai-key

# App URL — used to construct /challenge/[token] shareable links
# Dev: http://localhost:3000
# Prod: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional
# NEXTAUTH_SECRET=some-long-random-secret
# (If using NextAuth for admin auth)
